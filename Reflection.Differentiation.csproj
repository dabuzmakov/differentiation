<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <StartupObject>Reflection.Differentiation.Program</StartupObject>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="*.Initial.*" />
    <None Include="*.Initial.*" />
    <Compile Remove="*.WrongAnswer.*" />
    <None Include="*.WrongAnswer.*" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="NUnit" Version="4.2.2" />
    <PackageReference Include="NUnit3TestAdapter" Version="6.2.0" />
    <PackageReference Include="NUnitLite" Version="4.2.2" />
  </ItemGroup>
</Project>
